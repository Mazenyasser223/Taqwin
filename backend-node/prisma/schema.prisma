// Taqwin — PostgreSQL schema. Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  athlete
  trainer
  gym
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

// ─── Auth / Identity ─────────────────────────────────────────────────────────

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String?   @map("password_hash")
  googleId               String?   @unique @map("google_id")
  role                   Role      @default(athlete)
  emailVerifiedAt        DateTime? @map("email_verified_at")
  verificationCode       String?   @map("verification_code")
  verificationCodeExpiry DateTime? @map("verification_code_expiry")
  passwordResetToken     String?   @unique @map("password_reset_token")
  passwordResetExpiry    DateTime? @map("password_reset_expiry")
  pendingEmail           String?   @map("pending_email")
  emailChangeCode        String?   @map("email_change_code")
  emailChangeCodeExpiry  DateTime? @map("email_change_code_expiry")
  twoFactorEnabled       Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret        String?   @map("two_factor_secret")
  phone                  String?   @unique @map("phone")
  phoneVerifiedAt        DateTime? @map("phone_verified_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  profile           Profile?
  ownedGyms         Gym[]              @relation("GymOwner")
  gymMemberships    GymMembership[]
  gymCheckIns       GymCheckIn[]
  workoutLogs       WorkoutLog[]
  createdWorkouts   Workout[]          @relation("WorkoutCreator")
  foodLogs          FoodLog[]
  orders            Order[]
  athleteBookings   TrainerBooking[]   @relation("AthleteBookings")
  trainerBookings   TrainerBooking[]   @relation("TrainerBookings")
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  postLikes         CommunityPostLike[]
  postReposts       CommunityPostRepost[]
  following         CommunityFollow[]    @relation("UserFollowing")
  followers         CommunityFollow[]    @relation("UserFollowers")
  ownedGroups       CommunityGroup[]     @relation("GroupOwner")
  groupMemberships  CommunityGroupMember[]
  conversationParticipants CommunityConversationParticipant[]
  sentMessages      CommunityMessage[]
  notifications     Notification[]
  settings          UserSettings?
  supportTickets    SupportTicket[]

  @@map("users")
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
}

enum SupportTicketCategory {
  account
  booking
  membership
  payments
  technical
  other
}

model SupportTicket {
  id          String                @id @default(uuid())
  userId      String                @map("user_id")
  category    SupportTicketCategory @default(other)
  subject     String
  description String                @db.Text
  imageUrl    String?               @map("image_url")
  status      SupportTicketStatus   @default(open)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("support_tickets")
}

model UserSettings {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  language               String   @default("en")
  theme                  String   @default("dark")
  notifyWorkoutReminders Boolean  @default(true) @map("notify_workout_reminders")
  notifyAiSuggestions    Boolean  @default(true) @map("notify_ai_suggestions")
  notifyPromotional      Boolean  @default(true) @map("notify_promotional")
  shareWithTrainers      Boolean  @default(true) @map("share_with_trainers")
  publicProfile          Boolean  @default(false) @map("public_profile")
  unitSystem             String   @default("metric") @map("unit_system")
  timezone               String   @default("UTC") @map("timezone")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Profile {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  displayName  String?   @map("display_name")
  avatarUrl    String?   @map("avatar_url")
  coverUrl     String?   @map("cover_url")
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  gender       String?
  height       Float?
  weight       Float?
  fitnessGoal  String?   @map("fitness_goal")
  fitnessLevel String?   @map("fitness_level")
  medicalNotes String?   @map("medical_notes") @db.Text
  onboardingData Json?   @map("onboarding_data")

  // Trainer fields
  bio             String? @db.Text
  specialties     String? @db.Text
  yearsExperience Int?    @map("years_experience")

  // Gym / business fields
  businessName    String? @map("business_name")
  businessAddress String? @map("business_address") @db.Text
  businessPhone   String? @map("business_phone")
  websiteUrl      String? @map("website_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Gyms ────────────────────────────────────────────────────────────────────

model Gym {
  id          String  @id @default(uuid())
  ownerId     String  @map("owner_id")
  name        String
  location    String
  bio         String? @db.Text
  imageUrl    String? @map("image_url")
  phone       String?
  maxCapacity Int     @default(100) @map("max_capacity")
  amenities   String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner       User            @relation("GymOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships GymMembership[]
  checkIns    GymCheckIn[]

  @@map("gyms")
}

model GymMembership {
  id        String    @id @default(uuid())
  gymId     String    @map("gym_id")
  userId    String    @map("user_id")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")

  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gymId, userId])
  @@map("gym_memberships")
}

model GymCheckIn {
  id          String   @id @default(uuid())
  gymId       String   @map("gym_id")
  userId      String   @map("user_id")
  checkedInAt DateTime @default(now()) @map("checked_in_at")

  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gym_check_ins")
}

// ─── Workouts ────────────────────────────────────────────────────────────────

model Workout {
  id          String  @id @default(uuid())
  createdById String? @map("created_by_id")
  title       String
  category    String
  difficulty  String
  durationMin Int     @map("duration_min")
  calories    Int
  imageUrl    String? @map("image_url")
  description String? @db.Text
  isPublic    Boolean @default(true) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")

  createdBy User?        @relation("WorkoutCreator", fields: [createdById], references: [id], onDelete: Cascade)
  logs      WorkoutLog[]

  @@map("workouts")
}

model WorkoutLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  workoutId   String   @map("workout_id")
  loggedAt    DateTime @default(now()) @map("logged_at")
  durationMin Int?     @map("duration_min")
  notes       String?  @db.Text

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@map("workout_logs")
}

// ─── Nutrition ───────────────────────────────────────────────────────────────

model FoodItem {
  id       String  @id @default(uuid())
  fdcId    Int?    @unique @map("fdc_id")
  name     String
  category String
  calories Int
  protein  Float
  carbs    Float
  fat      Float
  imageUrl String? @map("image_url")
  isPublic Boolean @default(true) @map("is_public")

  logs FoodLog[]

  @@map("food_items")
}

model FoodLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  foodItemId String   @map("food_item_id")
  loggedAt   DateTime @default(now()) @map("logged_at")
  grams      Float

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)

  @@map("food_logs")
}

// ─── Marketplace ─────────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(uuid())
  name        String
  brand       String
  price       Float
  imageUrl    String? @map("image_url")
  description String? @db.Text
  stock       Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  status    OrderStatus @default(pending)
  total     Float
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  quantity  Int    @default(1)
  unitPrice Float  @map("unit_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── Trainer Bookings ────────────────────────────────────────────────────────

model TrainerBooking {
  id          String        @id @default(uuid())
  athleteId   String        @map("athlete_id")
  trainerId   String        @map("trainer_id")
  scheduledAt DateTime      @map("scheduled_at")
  status      BookingStatus @default(pending)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  athlete User @relation("AthleteBookings", fields: [athleteId], references: [id], onDelete: Cascade)
  trainer User @relation("TrainerBookings", fields: [trainerId], references: [id], onDelete: Cascade)

  @@map("trainer_bookings")
}

// ─── Community ───────────────────────────────────────────────────────────────

model CommunityPost {
  id           String   @id @default(uuid())
  authorId     String   @map("author_id")
  groupId      String?  @map("group_id")
  content      String   @db.Text
  imageUrl     String?  @map("image_url")
  videoUrl     String?  @map("video_url")
  mediaType    String?  @map("media_type")
  likesCount   Int      @default(0) @map("likes_count")
  repostsCount Int      @default(0) @map("reposts_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  author   User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    CommunityGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  comments CommunityComment[]
  likes    CommunityPostLike[]
  reposts  CommunityPostRepost[]

  @@index([createdAt])
  @@index([groupId])
  @@map("community_posts")
}

model CommunityPostRepost {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("community_post_reposts")
}

model CommunityFollow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  status      String   @default("accepted") // accepted | pending
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("community_follows")
}

model CommunityGroup {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  name        String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   User                   @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members CommunityGroupMember[]
  posts   CommunityPost[]

  @@map("community_groups")
}

model CommunityGroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  group CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("community_group_members")
}

model CommunityConversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  participants CommunityConversationParticipant[]
  messages     CommunityMessage[]

  @@map("community_conversations")
}

model CommunityConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")

  conversation CommunityConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("community_conversation_participants")
}

model CommunityMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation CommunityConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("community_messages")
}

model CommunityComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("community_comments")
}

model CommunityPostLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  emoji     String   @default("like")
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("community_post_likes")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}
