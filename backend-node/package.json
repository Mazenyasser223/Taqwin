{
  "name": "taqwin-backend",
  "version": "0.1.0",
  "description": "Taqwin main API (auth, users, gyms, bookings, marketplace)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:seed:force": "node prisma/seed.js --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\" --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,json}\" \"tests/**/*.{js,json}\" \"prisma/**/*.{prisma,sql,js}\"",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "taqwin",
    "fitness",
    "api"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.0",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}
