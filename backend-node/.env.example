# Copy to .env and fill values. Never commit .env.

PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# DATABASE_URL: pooler URL (Supabase: port 6543, pgbouncer=true&connection_limit=1)
# DIRECT_URL : direct URL for migrations (Supabase: port 5432)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-32+char-random
JWT_EXPIRES_IN=7d
# Set to true to show email verification step after signup (default: skip, go straight to onboarding)
# REQUIRE_EMAIL_VERIFICATION=true

# Google OAuth (optional). Set GOOGLE_CALLBACK_URL to your Render URL in production.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Public origin of the SPA (Vercel URL in prod, http://localhost:5173 locally).
FRONTEND_URL=http://localhost:5173

# Optional: cap auth requests per IP per 15 minutes (default: 60 prod / 200 dev)
# AUTH_RATE_LIMIT_MAX=60
# Emergency DB token for /api/admin/emergency-migrate-role-enum
# EMERGENCY_MIGRATE_TOKEN=long-random-string

# -----------------------------------------------------------------------------
# Email (Gmail SMTP via app password)
# -----------------------------------------------------------------------------
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Supabase Storage (signed-URL uploads)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key
SUPABASE_STORAGE_BUCKET=taqwin-uploads

# -----------------------------------------------------------------------------
# Anthropic Claude (server-side proxy for every /api/ai/* route)
#   /api/ai/chat            — text coach
#   /api/ai/form-check/*    — live form tracer coaching
#   /api/ai/food/*          — multi-item food detection (Claude Vision) + nutrition
#   /api/ai/plan/*          — onboarding-driven workout + diet plan generator
#   /api/ai/notify/*        — smart notification personalization
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Per-user-per-minute rate caps (defaults shown — uncomment to override).
# AI_RATE_LIMIT_MAX=20                  # /api/ai/chat
# AI_FORM_CHECK_RATE_LIMIT_MAX=60       # feedback calls during a live set
# AI_FOOD_DETECT_RATE_LIMIT_MAX=10      # vision is expensive — keep low
# AI_PLAN_RATE_LIMIT_MAX=5              # plan generation is heavy

# Legacy Gemini key — kept until the Claude swap lands so the old /api/ai/chat
# keeps working in environments that haven't been re-provisioned yet.
# GEMINI_API_KEY=your-gemini-api-key
