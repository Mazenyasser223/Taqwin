# Copy to .env and fill values. Never commit .env.

PORT=4000
NODE_ENV=development

# PostgreSQL (Sprint 1) — local or AWS RDS
# Local:  postgresql://postgres:password@localhost:5432/taqwin
# AWS (use sslmode=require): postgresql://USER:PASSWORD@your-instance.xxxxx.region.rds.amazonaws.com:5432/taqwin?sslmode=require
# DATABASE_URL=postgresql://...

# MongoDB (Sprint 2+)
# MONGODB_URI=mongodb://localhost:27017/taqwin

# Redis (Sprint 1 optional: sessions, cache; Sprint 2+: queues)
# REDIS_URL=redis://localhost:6379

# AWS S3 (avatars, body photos, uploads)
# AWS_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=taqwin-uploads

# JWT (Sprint 1) — required for /auth/register and /auth/login
JWT_SECRET=your-secret-min-32-chars-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Gmail SMTP (for sending verification emails)
# Use App Password, not regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
