# Copy to .env and fill values. Never commit .env.

PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# DATABASE_URL: pooler URL (Supabase: port 6543, pgbouncer=true&connection_limit=1)
# DIRECT_URL : direct URL for migrations (Supabase: port 5432)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-32+char-random
JWT_EXPIRES_IN=7d
# Set to true to show email verification step after signup (default: skip, go straight to onboarding)
# Require 6-digit email code after signup (default: on when Gmail is configured)
# REQUIRE_EMAIL_VERIFICATION=false

# Google OAuth (optional). Set GOOGLE_CALLBACK_URL to your Render URL in production.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Public origin of the SPA — used for OAuth redirects and CORS (comma-separated for multiple).
# Production example: FRONTEND_URL=https://taqwin.vercel.app
FRONTEND_URL=http://localhost:3001

# Optional extra CORS origins (comma-separated), e.g. a custom domain.
# CORS_ALLOWED_ORIGINS=https://www.taqwin.com

# In production, allow any https://*.vercel.app origin (preview deploys). Set false to disable.
# CORS_ALLOW_VERCEL=true

# Optional: cap auth requests per IP per 15 minutes (default: 60 prod / 200 dev)
# AUTH_RATE_LIMIT_MAX=60
# Emergency DB token for /api/admin/emergency-migrate-role-enum
# EMERGENCY_MIGRATE_TOKEN=long-random-string

# -----------------------------------------------------------------------------
# Email (Gmail SMTP via app password)
# -----------------------------------------------------------------------------
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Twilio Verify (SMS password reset) — https://console.twilio.com
# Trial: verify recipient numbers under Phone Numbers → Verified Caller IDs
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxx

# -----------------------------------------------------------------------------
# Supabase Storage (signed-URL uploads)
# -----------------------------------------------------------------------------
# If omitted, SUPABASE_URL is inferred from DATABASE_URL (postgres.PROJECT_REF).
# Without SERVICE_KEY, uploads use local disk at backend-node/uploads/ (dev only).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Client-safe key (optional; not used for uploads today)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Required for POST /api/uploads/sign — use service_role from Dashboard → API
SUPABASE_SERVICE_KEY=eyJ...service-role-key
SUPABASE_STORAGE_BUCKET=taqwin-uploads
# Optional: public API base for local upload URLs (default: request host)
# API_PUBLIC_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Anthropic Claude (server-side proxy for every /api/ai/* route)
#   /api/ai/chat            — text coach
#   /api/ai/form-check/*    — live form tracer coaching
#   /api/ai/food/*          — multi-item food detection (Claude Vision) + nutrition
#   /api/ai/plan/*          — onboarding-driven workout + diet plan generator
#   /api/ai/notify/*        — smart notification personalization
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Per-user-per-minute rate caps (defaults shown — uncomment to override).
# AI_RATE_LIMIT_MAX=20                  # /api/ai/chat
# AI_FORM_CHECK_RATE_LIMIT_MAX=60       # feedback calls during a live set
# AI_FOOD_DETECT_RATE_LIMIT_MAX=10      # vision is expensive — keep low
# AI_PLAN_RATE_LIMIT_MAX=5              # plan generation is heavy

# Legacy Gemini key — kept until the Claude swap lands so the old /api/ai/chat
# keeps working in environments that haven't been re-provisioned yet.
# GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# USDA FoodData Central (nutrition library search + import)
# Sign up: https://fdc.nal.usda.gov/api-key-signup
# -----------------------------------------------------------------------------
USDA_FDC_API_KEY=your-data-gov-fdc-api-key

# Optional Redis — shared FDC cache across instances / restarts (Upstash, local Docker, etc.)
# REDIS_URL=redis://localhost:6379
# FDC_FILTER_PAGE_BATCH=4          # USDA pages fetched in parallel per batch (default 4)
# FDC_FILTER_MAX_BATCHES=3         # max batches when filters are active (default 3 → up to 12 pages)
# FDC_PAGE_CACHE_TTL_MS=600000     # per USDA page cache (default 10 min)
# FDC_FILTERED_CACHE_TTL_MS=300000 # filtered scan cache (default 5 min)
# FDC_RESPONSE_CACHE_TTL_MS=300000 # full /fdc/search response with filters (default 5 min)
# FDC_RESPONSE_PLAIN_CACHE_TTL_MS=900000 # /fdc/search without filters (default 15 min)
# FDC_AR_CACHE_TTL_MS=900000       # Arabic overlay cache (default 15 min)
# FDC_RESOLVE_CACHE_TTL_MS=1800000 # resolved search query cache (default 30 min)
# FDC_RESOLVE_CACHE_MAX=500
# FDC_TRANSLATE_CONCURRENCY=24     # parallel EN→AR food name translations
# FDC_WARM_CACHE=true              # background warm on server start (set false to disable)
# FDC_WARM_CONCURRENCY=2           # parallel warm tasks
# FDC_WARM_GAP_MS=120              # pause between warm tasks (USDA rate limits)
# FDC_WARM_LANGS=ar                # ar, en, or ar,en
# FDC_CLIENT_CACHE_SEC=300         # Cache-Control on /fdc/search responses
# FDC_FILTER_PAGE_BATCH=2          # USDA pages per parallel batch when filters on (default 2)
# FDC_FILTER_MAX_BATCHES=2         # max batches when filters on (default 2)
# FDC_MEMORY_CACHE_MAX=400         # L1 in-process entry cap
